# Palworld Server Connection
PALWORLD_HOST=127.0.0.1
PALWORLD_REST_PORT=8212
PALWORLD_ADMIN_PASSWORD=your_admin_password_here

# Discord OAuth2 (must match your bot's Discord application)
DISCORD_CLIENT_ID=your_discord_app_id
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_TOKEN=your_bot_token_here
GUILD_ID=your_discord_server_id

# Dashboard URL (no trailing slash)
BASE_URL=http://localhost:3000

# Discord Role ID for admin access (optional — guild owner is always admin)
# Find this in Discord: Server Settings > Roles > right-click role > Copy ID
DASHBOARD_ADMIN_ROLE_ID=
# Discord Role ID for mod access (can save, shutdown, start)
DASHBOARD_MOD_ROLE_ID=

# Session & Server
SESSION_SECRET=generate-a-random-64-char-string-here
PORT=3000
NODE_ENV=production
